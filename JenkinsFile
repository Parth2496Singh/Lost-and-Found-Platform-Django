@Library("Shared") _
pipeline {
    agent {label "vinod"}
    
    stages{
        stage("Pipeline_Begin"){
            steps{
                echo "this pipeline is now starting"
            }
        }
        stage("Hello"){
            steps{
                script{
                    hello()
                }
            }
        }
        stage("Code"){
            steps{
                script{
                    clone("https://github.com/Parth2496Singh/Lost-and-Found-Platform-V2.git", "main")
                }
            }
        }
        stage("Build"){
            steps{
                script{
                    build("django-jenkins", "latest")
                }
            }
        }
        stage("Push to Dockerhub"){
            steps{
                script{
                    dockerhub_push("django-jenkins", "latest", "parthsingh2496")
                }
            }
        }
        stage("Testing"){
            steps{
            echo "Testing the code"
            }
        }
        stage("Deploy"){
            steps{
            echo "Deploying the code"
            sh "docker compose down && docker compose up -d"
            }
        }
        stage("Deploy to K8s") {
            steps {
                script {
                    withKubeConfig([credentialsId: 'k8s-secret', serverUrl: '']) {
                        sh "kubectl apply -f k8s/namespace.yml"
                        sh "kubectl apply -f k8s/."  
                        // Optional: Force a rollout to pull the latest image from Docker Hub
                        sh "kubectl rollout restart deployment/lost-found-deployment"
                        }
                }
            }
        }
}
